# Server-only OpenAI-compatible provider configuration.
# Never expose API keys through NEXT_PUBLIC_*.
UNITY2_AI_BASE_URL=https://unity2.ai/
UNITY2_AI_API_KEY=

# Required for live AI calls.
# Case generation uses JSON mode; investigation chat uses plain text streaming over /ws/agent.
# Leave blank to keep chat on deterministic local fallback replies.
UNITY2_AI_MODEL=

# Local MySQL cache for pre-generated cases.
DATABASE_URL=mysql://root:123456@localhost:3306/truth_divergence
CASE_CACHE_TARGET=5
CASE_CACHE_INTERVAL_MS=60000

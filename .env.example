# 服务端 OpenAI-compatible 文本模型配置。
# 不要把任何 API Key 放进 NEXT_PUBLIC_*，否则会暴露到浏览器。
UNITY2_AI_BASE_URL=https://unity2.ai/
UNITY2_AI_API_KEY=

# 实时 AI 调用需要填写模型名。
# 案件生成使用 JSON 模式；调查聊天通过 /ws/agent 做文本流式返回。
# 留空时会走本地 fallback 回复，方便无模型调试。
UNITY2_AI_MODEL=

# 服务端图片生成配置。
# OPENAI_IMAGE_API_KEY 可以填写 OpenAI 或兼容图片服务的 Key。
OPENAI_IMAGE_BASE_URL=https://api.openai.com/
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=high
OPENAI_IMAGE_FORMAT=png
OPENAI_IMAGE_MODERATION=auto
CASE_VISUALS_ENABLED=true
# opening：只生成封面；preload：生成封面和少量隐藏候选图；full：生成全部规划图片。
CASE_VISUALS_SCOPE=preload
CASE_VISUALS_PRELOAD_LIMIT=8
CASE_VISUALS_RUNTIME_ENABLED=true
CASE_VISUALS_RUNTIME_LIMIT=2
CASE_VISUALS_CONCURRENCY=2

# 视觉资源存储方式。
# local：生成图保存到本项目的 CASE_VISUALS_DIR；minio：生成图上传到 MinIO/S3-compatible bucket。
VISUAL_STORAGE_DRIVER=local
CASE_VISUALS_DIR=public/generated/cases

# 仅当 VISUAL_STORAGE_DRIVER=minio 时需要填写下面这些 MinIO 配置。
# MinIO 服务地址，只写主机名或 IP，不要带 http://。
MINIO_ENDPOINT=localhost
# MinIO API 端口，默认本地 MinIO 通常是 9000。
MINIO_PORT=9000
# 是否使用 HTTPS 连接 MinIO；本地开发通常是 false。
MINIO_USE_SSL=false
# MinIO access key，相当于账号。
MINIO_ACCESS_KEY=
# MinIO secret key，相当于密码。
MINIO_SECRET_KEY=
# 存放生成图片的 bucket 名称。
MINIO_BUCKET=truth-divergence
# 浏览器访问图片时使用的公开基础地址。bucket 需要可公开读取，或这里指向你的公开代理/CDN。
MINIO_PUBLIC_URL=http://localhost:9000/truth-divergence
# 对象名前缀。最终对象路径类似 generated/cases/<caseId>/<kind>/<file>.png。
MINIO_PREFIX=generated/cases
# MinIO/S3 region；本地 MinIO 可以留空。
MINIO_REGION=
# 开发环境可以设为 true，让程序在 bucket 不存在时自动创建。
MINIO_CREATE_BUCKET=true
# 是否跳过 bucket 存在性检查；只有在权限受限但 bucket 已存在时才建议设为 true。
MINIO_SKIP_BUCKET_CHECK=false

# 本地 MySQL 案件缓存配置。
DATABASE_URL=mysql://root:123456@localhost:3306/truth_divergence
CASE_CACHE_TARGET=5
CASE_CACHE_INTERVAL_MS=60000

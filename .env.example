# Server-only OpenAI-compatible provider configuration.
# Never expose API keys through NEXT_PUBLIC_*.
UNITY2_AI_BASE_URL=https://unity2.ai/
UNITY2_AI_API_KEY=

# Required for live AI calls.
# Case generation uses JSON mode; investigation chat uses plain text streaming over /ws/agent.
# Leave blank to keep chat on deterministic local fallback replies.
UNITY2_AI_MODEL=

# Server-only image generation configuration.
# OPENAI_IMAGE_API_KEY may point to an OpenAI-compatible image provider key.
OPENAI_IMAGE_BASE_URL=https://api.openai.com/
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=high
OPENAI_IMAGE_FORMAT=png
OPENAI_IMAGE_MODERATION=auto
CASE_VISUALS_ENABLED=true
# opening: only generate the opening hero cover. full: generate cover, locations, portraits, clues, evidence.
CASE_VISUALS_SCOPE=opening
CASE_VISUALS_CONCURRENCY=2

# Local MySQL cache for pre-generated cases.
DATABASE_URL=mysql://root:123456@localhost:3306/truth_divergence
CASE_CACHE_TARGET=5
CASE_CACHE_INTERVAL_MS=60000
